{
  "name": "real-time-messenger-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal backend skeleton for the real-time messenger learning project.",
  "scripts": {
    "start": "ts-node src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "start:prod": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/websockets": "^11.1.26",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.26",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  }
}
